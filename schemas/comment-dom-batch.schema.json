{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.comment-crawler/schemas/comment-dom-batch.schema.json",
  "title": "Comment DOM Batch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "batch_id",
    "task_id",
    "platform",
    "source_url",
    "captured_at",
    "scroll",
    "state",
    "limits",
    "candidates"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "comment-dom-batch-v1"
    },
    "batch_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "platform": {
      "type": "string",
      "enum": ["douyin", "xiaohongshu", "bilibili", "weibo", "unknown"]
    },
    "batch_kind": {
      "type": "string",
      "enum": ["capture", "model"]
    },
    "source_url": {
      "type": "string"
    },
    "captured_at": {
      "type": "string"
    },
    "scroll": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "before_top",
        "after_top",
        "viewport_height",
        "document_height"
      ],
      "properties": {
        "before_top": {
          "type": "number",
          "minimum": 0
        },
        "after_top": {
          "type": "number",
          "minimum": 0
        },
        "viewport_height": {
          "type": "number",
          "minimum": 0
        },
        "document_height": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "new_candidate_count",
        "seen_candidate_count",
        "has_more",
        "stop_reason"
      ],
      "properties": {
        "new_candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "seen_candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "has_more": {
          "type": "boolean"
        },
        "stop_reason": {
          "type": "string"
        },
        "declared_comment_count": {
          "type": "integer",
          "minimum": 0
        },
        "captured_record_count": {
          "type": "integer",
          "minimum": 0
        },
        "remaining_expand_count": {
          "type": "integer",
          "minimum": 0
        },
        "end_signal": {
          "type": "string"
        },
        "count_gap": {
          "type": "integer",
          "minimum": 0
        },
        "partial_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxCandidates",
        "maxCharsPerCandidate"
      ],
      "properties": {
        "maxCandidates": {
          "type": "integer",
          "minimum": 1
        },
        "maxCharsPerCandidate": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "candidate_hash",
          "dom_path",
          "role_hint",
          "inner_text",
          "html",
          "nearby_buttons",
          "rect",
          "captured_at"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "candidate_hash": {
            "type": "string"
          },
          "dom_path": {
            "type": "string"
          },
          "role_hint": {
            "type": "string",
            "enum": ["comment_candidate", "reply_candidate", "unknown"]
          },
          "inner_text": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "nearby_buttons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rect": {
            "type": "object",
            "additionalProperties": false,
            "required": ["top", "left", "width", "height"],
            "properties": {
              "top": {
                "type": "number"
              },
              "left": {
                "type": "number"
              },
              "width": {
                "type": "number",
                "minimum": 0
              },
              "height": {
                "type": "number",
                "minimum": 0
              }
            }
          },
          "captured_at": {
            "type": "string"
          },
          "capture_sort_mode": {
            "type": "string",
            "enum": ["hot", "time"]
          },
          "identity_mode": {
            "type": "string",
            "enum": ["dom_id", "composite_fingerprint"]
          },
          "source_comment_id": {
            "type": "string"
          },
          "source_parent_comment_id": {
            "type": "string"
          },
          "source_root_comment_id": {
            "type": "string"
          },
          "source_composite_fingerprint": {
            "type": "string"
          },
          "source_author_uid_href": {
            "type": "string"
          },
          "source_comment_text": {
            "type": "string"
          },
          "source_comment_timestamp": {
            "type": "string"
          },
          "source_reply_context": {
            "type": "string"
          },
          "source_root_context": {
            "type": "string"
          },
          "source_capture_batch_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "allOf": [
          {
            "if": {
              "required": ["identity_mode"],
              "properties": {
                "identity_mode": {
                  "const": "dom_id"
                }
              }
            },
            "then": {
              "required": ["source_comment_id"],
              "properties": {
                "source_comment_id": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          {
            "if": {
              "required": ["identity_mode"],
              "properties": {
                "identity_mode": {
                  "const": "composite_fingerprint"
                }
              }
            },
            "then": {
              "required": [
                "source_author_uid_href",
                "source_comment_text",
                "source_comment_timestamp",
                "source_reply_context",
                "source_root_context",
                "source_composite_fingerprint"
              ],
              "properties": {
                "source_author_uid_href": {
                  "type": "string",
                  "minLength": 1
                },
                "source_comment_text": {
                  "type": "string",
                  "minLength": 1
                },
                "source_comment_timestamp": {
                  "type": "string",
                  "minLength": 1
                },
                "source_reply_context": {
                  "type": "string"
                },
                "source_root_context": {
                  "type": "string",
                  "minLength": 1
                },
                "source_composite_fingerprint": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          {
            "if": {
              "required": ["identity_mode", "role_hint"],
              "properties": {
                "identity_mode": {
                  "const": "composite_fingerprint"
                },
                "role_hint": {
                  "const": "reply_candidate"
                }
              }
            },
            "then": {
              "properties": {
                "source_reply_context": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        ]
      }
    }
  }
}
