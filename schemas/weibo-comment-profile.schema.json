{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.comment-crawler/schemas/weibo-comment-profile.schema.json",
  "title": "Weibo Chrome Comment Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "platform",
    "identityMode",
    "postRootSelector",
    "commentRootSelector",
    "commentItemSelector",
    "replyContainerSelector",
    "scrollContainerSelector",
    "sortScopeSelector",
    "sorts",
    "endTexts",
    "safeReplyExpandPatterns",
    "identityAttributes"
  ],
  "properties": {
    "platform": {
      "type": "string",
      "const": "weibo"
    },
    "identityMode": {
      "type": "string",
      "enum": ["dom_id", "composite"]
    },
    "postRootSelector": { "$ref": "#/$defs/nonEmptyString" },
    "commentRootSelector": { "$ref": "#/$defs/nonEmptyString" },
    "commentItemSelector": { "$ref": "#/$defs/nonEmptyString" },
    "replyContainerSelector": { "$ref": "#/$defs/nonEmptyString" },
    "scrollContainerSelector": { "$ref": "#/$defs/nonEmptyString" },
    "sortScopeSelector": { "$ref": "#/$defs/nonEmptyString" },
    "sorts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hot", "time"],
      "properties": {
        "hot": { "$ref": "#/$defs/sort" },
        "time": { "$ref": "#/$defs/sort" }
      }
    },
    "endTexts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "safeReplyExpandPatterns": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "compositeIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authorHrefSelector",
        "commentTextSelector",
        "timestampSelector"
      ],
      "properties": {
        "authorHrefSelector": { "$ref": "#/$defs/nonEmptyString" },
        "commentTextSelector": { "$ref": "#/$defs/nonEmptyString" },
        "timestampSelector": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "identityAttributes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["comment", "parent", "root"],
      "properties": {
        "comment": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "parent": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "root": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["identityMode"],
        "properties": {
          "identityMode": { "const": "dom_id" }
        }
      },
      "then": {
        "properties": {
          "identityAttributes": {
            "properties": {
              "comment": { "minItems": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["identityMode"],
        "properties": {
          "identityMode": { "const": "composite" }
        }
      },
      "then": {
        "required": ["compositeIdentity"]
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "sort": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "selectedAttribute", "selectedValue"],
      "properties": {
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "selectedAttribute": { "$ref": "#/$defs/nonEmptyString" },
        "selectedValue": { "$ref": "#/$defs/nonEmptyString" }
      }
    }
  }
}
